graph TB
    subgraph Cluster
        subgraph Ingress
            IG[HTTPS Ingress]
        end

        subgraph SVCs
            SCoord[coordinator svc]
            SDec[decoder svc]
            SEnc[encoder svc]
            SMon[prometheus svc]
        end

        subgraph Deployments
            subgraph Coord
                C1[coordinator pod]
                C2[coordinator pod]
            end
            subgraph DecPool
                D1[decoder pod GPU]
                D2[decoder pod GPU]
                DN[decoder pod N GPU]
            end
            subgraph Enc
                EC[encoder core pod]
            end
            subgraph Mon
                PR[prometheus pod]
                GR[grafana pod]
                OC[otel collector pod]
            end
        end
    end

    IG --> SCoord
    IG --> SEnc
    SCoord --> C1
    SCoord --> C2

    C1 --> SDec
    C2 --> SDec

    SDec --> D1
    SDec --> D2
    SDec --> DN

    SEnc --> EC

    C1 --> SMon
    C2 --> SMon
    D1 --> SMon
    D2 --> SMon
    DN --> SMon
    EC --> SMon

    SMon --> PR
    PR --> GR
    PR --> OC
