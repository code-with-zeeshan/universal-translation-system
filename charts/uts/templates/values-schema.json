{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "coordinator": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "pullPolicy": {"type": "string"}
          },
          "required": ["repository", "tag"]
        },
        "replicaCount": {"type": "integer", "minimum": 1},
        "service": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "port": {"type": "integer", "minimum": 1}
          },
          "required": ["type", "port"]
        },
        "secret": {
          "type": "object",
          "properties": {
            "jwtSecret": {"type": "string"},
            "secret": {"type": "string"},
            "token": {"type": "string"},
            "internalServiceToken": {"type": "string"}
          }
        },
        "resources": {"type": "object"}
      },
      "required": ["image", "replicaCount", "service"]
    },
    "decoder": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "pullPolicy": {"type": "string"}
          },
          "required": ["repository", "tag"]
        },
        "replicaCount": {"type": "integer", "minimum": 1},
        "service": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "port": {"type": "integer", "minimum": 1}
          },
          "required": ["type", "port"]
        },
        "secret": {
          "type": "object",
          "properties": {
            "jwtSecret": {"type": "string"}
          }
        },
        "resources": {"type": "object"}
      },
      "required": ["image", "replicaCount", "service"]
    },
    "encoder": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {
          "type": "object",
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"},
            "pullPolicy": {"type": "string"}
          },
          "required": ["repository", "tag"]
        },
        "resources": {"type": "object"}
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "image": {
          "type": "object",
          "properties": {
            "repository": {"type": "string"},
            "tag": {"type": "string"}
          },
          "required": ["repository", "tag"]
        },
        "secret": {
          "type": "object",
          "properties": {
            "password": {"type": "string"}
          }
        },
        "resources": {"type": "object"}
      }
    }
  },
  "required": ["coordinator", "decoder"]
}
