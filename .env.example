# Universal Translation System — Environment Variables
# Copy this file to .env and customize for your environment.
# Required vars (no default) are marked [REQUIRED].
# All others have safe defaults.

# =============================================================================
# SECRETS & CREDENTIALS
# =============================================================================

# --- Role ---
# UTS_ROLE=general                                # "general", "coordinator", or "decoder"

# --- Coordinator Secrets [REQUIRED] ---
# Generate each with: openssl rand -hex 32
# For containerized deployments, prefer *_FILE variants (read from file path)
COORDINATOR_SECRET=use-openssl-rand-hex-32-to-generate-a-secure-cookie-key
COORDINATOR_JWT_SECRET=use-openssl-rand-hex-32-to-generate-a-secure-jwt-key
COORDINATOR_TOKEN=use-openssl-rand-hex-16-to-generate-a-secure-admin-token
INTERNAL_SERVICE_TOKEN=use-openssl-rand-hex-32-to-generate-a-secure-service-token
# File variants (path to secret file, overrides above vars when set):
# COORDINATOR_SECRET_FILE=/run/secrets/coordinator_secret
# COORDINATOR_JWT_SECRET_FILE=/run/secrets/coordinator_jwt_secret
# COORDINATOR_TOKEN_FILE=/run/secrets/coordinator_token
# INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# --- Decoder Secrets [REQUIRED] ---
DECODER_JWT_SECRET=use-openssl-rand-hex-32-to-generate-a-secure-key
# DECODER_JWT_SECRET_FILE=/run/secrets/decoder_jwt_secret

# --- JWT / JWKS ---
# RS256 keys (optional, for asymmetric auth). Paths preferred in containers.
# JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
# JWT_PRIVATE_KEY=paste-private-key-here
# JWT_PUBLIC_KEY=paste-public-key-here
JWT_KEY_IDS=
# JWT_ISS=https://api.yourdomain.com
# JWT_AUD=https://api.yourdomain.com
# JWKS_KEYS_JSON=[{"kty":"RSA","kid":"...","n":"...","e":"AQAB"}]
# UTS_JWT_DEFAULT_ALG=HS256                       # HS256 or RS256
# JWT_SECRET=                                      # fallback JWT secret

# --- HMAC Key [REQUIRED for secure serialization] ---
UTS_HMAC_KEY=use-openssl-rand-hex-32-to-generate-a-secure-hmac-key

# --- Vocab Signing Key ---
# UTS_VOCAB_SIGNING_KEY=                           # HMAC key for vocab pack signing/validation

# --- Redis [REQUIRED if REDIS_URL is not set] ---
REDIS_PASSWORD=replace-with-strong-random
# REDIS_PASSWORD_FILE=/run/secrets/redis_password      # File variant (overrides REDIS_PASSWORD)
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# --- Hugging Face Hub ---
# HF_TOKEN=hf_xxx                                 # [REQUIRED] for model/vocab downloads
# HF_TOKEN_FILE=/run/secrets/hf_token             # File variant (overrides HF_TOKEN)
HF_HUB_REPO_ID=code-with-zeeshan/universal-translation-system
HF_HUB_REVISION=main

# =============================================================================
# SERVICES: HOST / PORT / WORKERS
# =============================================================================

# --- Decoder ---
DECODER_HOST=0.0.0.0
DECODER_PORT=8001
DECODER_WORKERS=1
DECODER_API_URL=https://api.yourdomain.com/decode
DECODER_CONFIG_PATH=config/decoder_config.yaml
DECODER_POOL=decoder:8001

# --- Encoder ---
ENCODER_PORT=8000
ENCODER_API_URL=https://api.universal-translation.com/encode
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1
API_TITLE=Cloud Decoder API
# API_RATE_LIMIT=100                               # requests/min per client
# API_BURST_LIMIT=20                               # burst allowance
# API_TIMEOUT=30                                   # request timeout in seconds
# API_VERSION=1.0.0

# --- Coordinator ---
COORDINATOR_HOST=0.0.0.0
COORDINATOR_PORT=5100
COORDINATOR_WORKERS=1
COORDINATOR_TITLE=Universal Translation Coordinator
COORDINATOR_URL=http://localhost:5100
COORDINATOR_API_KEY=                            # [REQUIRED] for decoder node registration

# --- Coordinator Batcher ---
# COORDINATOR_BATCH_WINDOW_MS=50                # Accumulation window before forwarding (ms)

# --- Monitoring Stack ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=replace-with-strong-random
METRICS_PATH=/metrics
METRICS_COLLECTION_INTERVAL=15

# =============================================================================
# PATHS
# =============================================================================

# --- Model & Artifact Paths (under output/ root by default via RuntimeDirectoryManager) ---
ENCODER_MODEL_PATH=output/models/production/encoder.pt          # Encoder model file path
DECODER_MODEL_PATH=output/models/production/decoder.pt          # Decoder model file path
# FALLBACK_MODEL_PATH=                                   # No default (None = no fallback)
MODEL_PATH=/app/models/decoder_model.pt           # universal-decoder-node (Docker path)
MODEL_VERSION=1.0.0
MODELS_DIR=output/models
VOCAB_DIR=output/vocabulary/vocab
VOCABS_DIR=output/vocabulary/vocab                     # HF artifact store
ADAPTERS_DIR=output/models/adapters
CHECKPOINT_DIR=output/checkpoints

# --- Config ---
POOL_CONFIG_PATH=output/config/decoder_pool.json

# --- Data Directories ---
DATA_RAW_DIR=output/data/raw
DATA_PROCESSED_DIR=output/data/processed
DATA_SAMPLED_DIR=output/data/processed/sampled
DATA_FINAL_DIR=output/data/processed/augment
DATA_CACHE_DIR=output/data/processed/cache
DATA_ESSENTIAL_DIR=output/data/essential

# --- Misc Paths ---
LOG_DIR=output/logs
# DEFAULT_CONFIG_PATH=config/default_config.json    # code constant (not runtime)
# DEFAULT_MODEL_PATH=models/default_model           # code constant (not runtime)
# DEFAULT_VOCAB_PATH=vocabulary/default_vocab       # code constant (not runtime)
# DEFAULT_LOG_PATH=logs/system.log                  # code constant (not runtime)

# --- Model Web Paths (SDK) ---
MODEL_URL=/models/universal_encoder.onnx
VOCAB_URL=/vocabs
WASM_ENCODER_PATH=/wasm/encoder.js

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_SYSTEM_METRICS=true
ENABLE_GPU_METRICS=true
ENABLE_VOCABULARY_METRICS=true
ENABLE_PROFILING=false
ENABLE_MEMORY_MONITORING=true
ENABLE_FALLBACK=true
AUTO_MEMORY_CLEANUP=true
USE_WASM_ENCODER=true
USE_NATIVE_ENCODER=true
USE_ETCD=false
ENFORCE_HTTPS=false
REDIS_USE_MSGPACK=true
REDIS_HEALTH_CHECK_ENABLED=true
UTS_API_KEYS_USE_CREDMGR=false
UTS_TEST_MODE=                                  # set to "1" to skip external deps in tests
RUN_E2E_TESTS=                                  # set to "1" to run e2e integration tests

# =============================================================================
# INFERENCE / MODEL HYPERPARAMETERS
# =============================================================================

EMBEDDING_DIM=768
MAX_SEQUENCE_LENGTH=512
ENCODER_DEVICE=auto
DECODER_DEVICE=cuda
DECODER_BATCH_SIZE=32
DECODER_BEAM_SIZE=5
MAX_BATCH_TOKENS=8192
MAX_BATCH_SIZE=64
BATCH_TIMEOUT_MS=10
TOKEN_EXPIRY=3600

# =============================================================================
# REDIS
# =============================================================================

REDIS_KEY_PREFIX=translation:
REDIS_CONN_TIMEOUT=2
REDIS_READ_TIMEOUT=2
REDIS_HEALTH_CHECK_INTERVAL=30
# REDIS_PORT=6379                                # Only if non-default (bare form)
UTS_REDIS_PORT=6379

# =============================================================================
# PERFORMANCE / MONITORING
# =============================================================================

MONITORING_LOG_LEVEL=INFO
LOG_LEVEL=INFO
LOG_FORMAT=
PROFILE_OUTPUT_DIR=output/profiles
PROFILE_EXPORT_FORMAT=json
BOTTLENECK_THRESHOLD_MS=100.0
MEMORY_MONITOR_INTERVAL_SECONDS=60
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces   # OpenTelemetry OTLP HTTP
WIKI_DOWNLOAD_WORKERS=20                             # concurrent Wikipedia downloads (backtranslation)
UTS_GPU_TIER=                                        # override GPU detection: t4|l4|l40s|a100|h100|cpu
MEMORY_THRESHOLD_PERCENT=85
GPU_MEMORY_THRESHOLD_PERCENT=85
CLEANUP_THRESHOLD_PERCENT=80

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
CIRCUIT_BREAKER_TIMEOUT=10

# =============================================================================
# SERVICE DISCOVERY & ETCD
# =============================================================================

ETCD_HOST=localhost
ETCD_PORT=2379
ETCD_PREFIX=/universal-translation/decoders/
SERVICE_TTL=60
SERVICE_DISCOVERY_COORDINATOR_URL=http://localhost:5100
SERVICE_DISCOVERY_HEARTBEAT_INTERVAL=30
SERVICE_DISCOVERY_TIMEOUT=5
COORDINATOR_MIRROR_INTERVAL=30                    # seconds

# --- mDNS Service Discovery ---
MDNS_ENABLE=true
MDNS_SERVICE_TYPE=_universal-translate._tcp
MDNS_PORT=8000

# =============================================================================
# SECURITY / CORS / PROXIES
# =============================================================================

ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
TRUSTED_PROXIES=
TRUSTED_MODELS_DIR=models
TRUSTED_HASHES_FILE=trusted_model_hashes.txt
DECODER_API_VERSION=

# =============================================================================
# TRAINING & DISTRIBUTED
# =============================================================================

MASTER_ADDR=localhost
MASTER_PORT=12355
TORCH_COMPILE_DEBUG=0
TORCH_LOGS=+dynamo
TORCHDYNAMO_DISABLE_CACHE_LIMIT=1
TOKENIZERS_PARALLELISM=false
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
OMP_NUM_THREADS=4
CUDA_VISIBLE_DEVICES=0

TRAIN_TOTAL_STEPS=10000                           # optional, auto-compile hint
# EVOLVE_ANALYTICS_JSON=data/vocab_evolution_analytics.json

# =============================================================================
# UNIVERSAL DECODER NODE (udn)
# =============================================================================

DECODER_ENDPOINT=http://localhost:8001
DECODER_CONFIG=decoder_config.yaml                 # overrides DECODER_CONFIG_PATH for udn CLI
COORDINATOR_URL=http://localhost:5100
COORDINATOR_API_KEY=                              # [REQUIRED] for node registration

# --- GPU Detection ---
# Auto-detected on first run. Set explicitly to skip the prompt.
# DECODER_GPU_ENABLED=true
# DECODER_GPU=cuda                                 # cuda, mps, or cpu

# --- Local Decoder Preference (SDK) ---
# SDKs prefer a local decoder over cloud when available.
# LOCAL_DECODER_URL=http://localhost:8001
# PREFER_LOCAL_DECODER=true

# =============================================================================
# PREFETCH (decoder startup)
# =============================================================================

# Comma-separated lists; optional but speeds up cold start
# PREFETCH_VOCAB_GROUPS=latin,cjk
# PREFETCH_ADAPTERS=es,fr,ja
# PREFETCH_MODELS=production/encoder.onnx

# =============================================================================
# UTS-PREFIXED OVERRIDES (utils/constants.py)
# =============================================================================
# Each accepts both UTS_<NAME> and bare <NAME>. Uncomment to override defaults.

# --- Timing & retries ---
# UTS_DEFAULT_TIMEOUT=30
# UTS_MAX_RETRY_COUNT=3
# UTS_DEFAULT_BATCH_SIZE=64
# UTS_DEFAULT_BUFFER_SIZE=8192

# --- Caching & resource limits ---
# UTS_MAX_CACHE_SIZE=10000
# UTS_DEFAULT_CACHE_TTL=3600
# UTS_MAX_MEMORY_USAGE=1073741824
# UTS_MAX_FILE_SIZE=104857600

# --- Security ---
# UTS_TOKEN_EXPIRATION=1800
# UTS_REFRESH_TOKEN_EXPIRATION=604800
# UTS_PASSWORD_MIN_LENGTH=8
# UTS_PASSWORD_MAX_LENGTH=128
# UTS_MAX_LOGIN_ATTEMPTS=5
# UTS_LOCKOUT_DURATION=900

# --- Encoder dimensions ---
# UTS_ENCODER_EMBEDDING_DIM=512
# UTS_ENCODER_HIDDEN_DIM=1024
# UTS_ENCODER_NUM_LAYERS=6
# UTS_ENCODER_NUM_HEADS=8
# UTS_ENCODER_DROPOUT=0.1
# UTS_ENCODER_MAX_LENGTH=512

# --- Decoder dimensions ---
# UTS_DECODER_EMBEDDING_DIM=512
# UTS_DECODER_HIDDEN_DIM=1024
# UTS_DECODER_NUM_LAYERS=6
# UTS_DECODER_NUM_HEADS=8
# UTS_DECODER_DROPOUT=0.1
# UTS_DECODER_MAX_LENGTH=512

# --- Vocabulary ---
# UTS_VOCAB_SIZE=32000
# UTS_VOCAB_MIN_FREQUENCY=5
# UTS_VOCAB_SPECIAL_TOKENS=<pad>,<unk>,<bos>,<eos>
# UTS_VOCAB_PAD_ID=0
# UTS_VOCAB_UNK_ID=1
# UTS_VOCAB_BOS_ID=2
# UTS_VOCAB_EOS_ID=3

# --- API ---
# UTS_API_RATE_LIMIT=100
# UTS_API_BURST_LIMIT=20
# UTS_API_TIMEOUT=30
# UTS_API_VERSION=1.0.0

# --- Directory paths (all under output/ root) ---
# UTS_LOG_DIR=output/logs
# UTS_DATA_RAW_DIR=output/data/raw
# UTS_DATA_PROCESSED_DIR=output/data/processed
# UTS_DATA_SAMPLED_DIR=output/data/processed/sampled
# UTS_DATA_FINAL_DIR=output/data/processed/augment
# UTS_DATA_CACHE_DIR=output/data/processed/cache
# UTS_DATA_ESSENTIAL_DIR=output/data/essential
# UTS_MODELS_DIR=output/models
# UTS_MODELS_PRODUCTION_DIR=output/models/production
# UTS_MODELS_ENCODER_DIR=output/models/encoder
# UTS_MODELS_DECODER_DIR=output/models/decoder
# UTS_MODELS_ADAPTERS_DIR=output/models/adapters
# UTS_CHECKPOINT_DIR=output/checkpoints
# UTS_VOCAB_DIR=output/vocabulary/vocab
# UTS_CONFIG_DIR=output/config

# =============================================================================
# CI/CD & PUBLISHING (GitHub Actions secrets, not needed for local dev)
# =============================================================================
# MAVEN_USERNAME=
# MAVEN_PASSWORD=
# MAVEN_URL=
# NPM_TOKEN=
# COCOAPODS_TRUNK_TOKEN=
# PYPI_API_TOKEN=
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=
# DOCKERHUB_REPO=
# KUBECONFIG_STAGING_B64=
# KUBECONFIG_PRODUCTION_B64=
